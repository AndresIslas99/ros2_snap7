# Read a single variable from the PLC

# S7 area: DB, INPUT, OUTPUT, MERKER, COUNTER, TIMER
string area

# Data block number (only for area=DB)
uint16 db_number

# Byte offset
uint32 byte_offset

# Bit offset (0-7, for Bool)
uint8 bit_offset

# Data type: bool, byte, int, word, dint, dword, real, string
string data_type
---
# Whether the read was successful
bool success

# The value as string
string value_string

# Error message (empty on success)
string message
